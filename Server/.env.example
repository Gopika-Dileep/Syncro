OTP_EXPIRY=600
PASSWORD_RESET_EXPIRY=900
BCRYPT_SALT_ROUNDS=10
REFRESH_TOKEN_COOKIE_MAX_AGE=604800000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax